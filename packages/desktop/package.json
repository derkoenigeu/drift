{
  "name": "@db-mirror/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Drift — MySQL & MariaDB schema and data sync desktop app",
  "homepage": "https://github.com/derkoenigeu/drift",
  "author": {
    "name": "derkoenigeu",
    "email": "jonas.koenig@mindbox.de"
  },
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "pnpm build:main && pnpm build:renderer",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "start": "electron .",
    "package": "electron-builder",
    "test": "vitest run",
    "test:e2e": "pnpm build && playwright test",
    "test:e2e:ui": "pnpm build && playwright test --ui"
  },
  "dependencies": {
    "@db-mirror/core": "workspace:*",
    "electron-updater": "^6.8.3",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-vue": "^5.0.0",
    "electron": "30.5.1",
    "electron-builder": "^24.13.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.4.0"
  }
}
